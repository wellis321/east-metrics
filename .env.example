# Copy this file to .env and fill in your values.
# cp .env.example .env

# --- App ---
APP_ENV=local
APP_URL=http://localhost:8892
SESSION_SECRET=change_this_secret_in_production

# --- Local MAMP ---
DB_HOST=127.0.0.1
DB_PORT=8889
DB_DATABASE=east_ren_metrics
DB_USERNAME=root
DB_PASSWORD=root
DB_CHARSET=utf8mb4

# --- Hostinger (hPanel → Databases) ---
# APP_ENV=production
# APP_URL=https://dodgerblue-wombat-806788.hostingersite.com
# SESSION_SECRET=a_long_random_string_for_production

# East Renfrewshire Housing Metrics app data (this app's own database)
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=u123456789_erm_metrics
# DB_USERNAME=u123456789_erm_metrics
# DB_PASSWORD=your_database_password
# DB_CHARSET=utf8mb4

# Shared auth database (users, login_attempts, password_setup_tokens)
# Point these at the same SOR database used by SOR system / AS-IS so the
# same accounts work across all three apps. If omitted, auth falls back to
# the main DB_* connection above.
# AUTH_DB_HOST=localhost
# AUTH_DB_PORT=3306
# AUTH_DB_NAME=u123456789_sor_management
# AUTH_DB_USER=u123456789_sor_management
# AUTH_DB_PASS=your_sor_database_password

# Sibling ERC digital tools — cross-linked in the footer. Defaults below are
# the real deployed URLs; override only if they ever move.
# SOR_SITE_URL=https://papayawhip-hamster-802775.hostingersite.com
# ERC_SITE_URL=https://aqua-quetzal-992173.hostingersite.com
# ASIS_SITE_URL=https://slategray-cat-335719.hostingersite.com
